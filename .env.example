# ScratchBird Benchmarks environment defaults.
#
# Copy to .env and adjust if your engine clones are not siblings of this repo.

FIREBIRD_REPO_PATH=../firebird
MYSQL_REPO_PATH=../mysql-server
POSTGRESQL_REPO_PATH=../postgresql

# Optional defaults for matrix runs.
BENCHMARK_ENGINES=firebird,mysql,postgresql
BENCHMARK_SUITES=regression,stress,acid,performance,tpc-c,tpc-h,engine-differential

# Optional host ports used by local dockerized engines.
BENCHMARK_FIREBIRD_PORT=3050
BENCHMARK_MYSQL_PORT=3306
BENCHMARK_POSTGRESQL_PORT=5432
